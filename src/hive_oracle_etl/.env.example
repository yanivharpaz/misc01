# -----------------------------------------------------------------------------
# Job identity
# -----------------------------------------------------------------------------
JOB_NAME=hive_orders_to_oracle
LOG_LEVEL=INFO
DRY_RUN=false

# -----------------------------------------------------------------------------
# Hive / Hadoop source
# -----------------------------------------------------------------------------
HIVE_HOST=hiveserver2.example.com
HIVE_PORT=10000
HIVE_DATABASE=sales_dw
HIVE_TABLE=orders
HIVE_USERNAME=hive_reader
HIVE_PASSWORD=change_me
# Common values: NOSASL, NONE, LDAP, KERBEROS, CUSTOM. Match your HiveServer2 setup.
HIVE_AUTH=LDAP
HIVE_KERBEROS_SERVICE_NAME=hive
HIVE_CREATED_COLUMN=created
# Leave empty to select TARGET_COLUMNS. Use Hive source column names when they differ.
HIVE_SELECT_COLUMNS=order_id,customer_id,amount,status,created
# Optional static source filter. Example: country = 'IL'
HIVE_EXTRA_WHERE=
# Optional PyHive configuration JSON. Example: {"hive.execution.engine":"tez"}
HIVE_CONFIGURATION_JSON={}

# -----------------------------------------------------------------------------
# Oracle 19c target
# -----------------------------------------------------------------------------
ORACLE_USER=APP_ETL
ORACLE_PASSWORD=change_me
# Easy Connect syntax: host:port/service_name
ORACLE_DSN=oracle19c.example.com:1521/ORCLPDB1
ORACLE_TARGET_TABLE=APP_ETL.ORDERS
ORACLE_STAGE_TABLE=APP_ETL.ORDERS_STG
ORACLE_CONTROL_TABLE=APP_ETL.ETL_WATERMARK

# Oracle target columns, in target-table order. Stage must contain these plus ETL metadata.
TARGET_COLUMNS=ORDER_ID,CUSTOMER_ID,AMOUNT,STATUS,CREATED
KEY_COLUMNS=ORDER_ID
TARGET_CREATED_COLUMN=CREATED

# Optional source-to-target rename map applied after Hive fetch.
# Example: {"orderid":"ORDER_ID","create_ts":"CREATED"}
COLUMN_RENAMES_JSON={}
UPPERCASE_COLUMN_NAMES=true

# -----------------------------------------------------------------------------
# Incremental loading behavior
# -----------------------------------------------------------------------------
# Initial value used only when JOB_NAME is not yet present in ETL_WATERMARK.
INITIAL_WATERMARK=1970-01-01T00:00:00+00:00
# Re-read a small interval every run to catch late-arriving Hive rows.
LOOKBACK_MINUTES=180
# Do not read the most recent N minutes to avoid in-flight writes.
SAFETY_LAG_MINUTES=10
# 200k daily rows usually means four Hive chunks with this default.
CHUNK_SIZE=50000
INSERT_BATCH_SIZE=10000
ORACLE_STMT_CACHE_SIZE=50
